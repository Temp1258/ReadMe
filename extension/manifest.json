{
  "manifest_version": 3,
  "name": "ReadMe",
  "description": "A lightweight Chrome/Edge extension for chat.",
  "version": "0.1.0",
  "icons": {
    "16": "dist/icons/icon-16.png",
    "32": "dist/icons/icon-32.png",
    "48": "dist/icons/icon-48.png",
    "128": "dist/icons/icon-128.png"
  },
  "action": {
    "default_title": "ReadMe",
    "default_popup": "dist/index.html",
    "default_icon": {
      "16": "dist/icons/icon-16.png",
      "32": "dist/icons/icon-32.png",
      "48": "dist/icons/icon-48.png",
      "128": "dist/icons/icon-128.png"
    }
  },
  "options_page": "dist/options.html",
  "background": {
    "service_worker": "dist/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "offscreen",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.deepgram.com/*",
    "https://api.siliconflow.cn/*"
  ]
}
