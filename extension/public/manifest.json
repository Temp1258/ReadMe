{
  "manifest_version": 3,
  "name": "ReadMe",
  "description": "A lightweight Chrome/Edge extension for chat.",
  "version": "0.1.0",
  "action": {
    "default_title": "ReadMe",
    "default_popup": "index.html"
  },
  "options_page": "options.html",
  "permissions": [
    "offscreen",
    "storage",
    "tabCapture"
  ],
  "host_permissions": [
    "https://api.openai.com/*"
  ]
}
